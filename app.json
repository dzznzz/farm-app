{
  "expo": {
    "name": "농장관리",
    "slug": "dzznzz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F8F6FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dzznzz.farm",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "수확 동선 추적을 위해 위치 접근이 필요합니다.",
        "NSLocationAlwaysUsageDescription": "백그라운드 수확 동선 추적을 위해 위치 접근이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F6FF"
      },
      "package": "com.dzznzz.farm",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "수확 동선 추적을 위해 위치 접근이 필요합니다."
        }
      ]
    ],
    "scheme": "dzznzz"
  }
}
