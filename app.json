{
  "expo": {
    "name": "농장관리",
    "slug": "dzznzz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F8F6FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dznz.farm",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "수확 동선 추적을 위해 위치 접근이 필요합니다.",
        "NSLocationAlwaysUsageDescription": "백그라운드 수확 동선 추적을 위해 위치 접근이 필요합니다.",
        "NSContactsUsageDescription": "판매 거래처 연락처 관리를 위해 연락처 접근이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.dzznzz.farm",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "수확 동선 추적을 위해 위치 접근이 필요합니다."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "판매 거래처 연락처 관리를 위해 연락처 접근이 필요합니다."
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "scheme": "dzznzz",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4dcebc72-5b6c-4615-b2f5-203fa25bbb61"
      }
    }
  }
}
